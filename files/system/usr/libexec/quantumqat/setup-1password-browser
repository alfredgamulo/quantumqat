#!/usr/bin/env bash
#
# Set up 1Password (native /opt install) <-> Flatpak browser integration for the
# CURRENT user. Bridges the browser's native-messaging request out of the Flatpak
# sandbox to the host 1Password-BrowserSupport binary via `flatpak-spawn --host`.
#
# Usage: setup-1password-browser [brave|chrome|firefox|<flatpak-app-id>]
#
# The system allowlist (/etc/1password/custom_allowed_browsers) is baked into the
# image; this script only sets up the per-user wrapper, manifest, and override.

set -euo pipefail

BROWSER="${1:-brave}"

# 1Password browser-extension IDs (from the official native-messaging manifests)
CHROMIUM_ALLOWED='"allowed_origins": [
        "chrome-extension://hjlinigoblmkhjejkmbegnoaljkphmgo/",
        "chrome-extension://gejiddohjgogedgjnonbofjigllpkmbf/",
        "chrome-extension://khgocmkkpikpnmmkgmdnfckapcdkgfaf/",
        "chrome-extension://aeblfdkhhhdcdjpifhhbdiojplfjncoa/",
        "chrome-extension://dppgmdbiimibapkepcbdbmkaabgiofem/"
    ]'
FIREFOX_ALLOWED='"allowed_extensions": [
        "{0a75d802-9aed-41e7-8daa-24c067386e82}",
        "{25fc87fa-4d31-4fee-b5c1-c32a7844c063}",
        "{d634138d-c276-4fc8-924b-40a0ea21d284}"
    ]'

# Map a friendly name -> (Flatpak app id, engine). Raw app ids pass through.
case "$BROWSER" in
  brave)     FLATPAK_ID="com.brave.Browser";                         TYPE="chromium" ;;
  chrome)    FLATPAK_ID="com.google.Chrome";                         TYPE="chromium" ;;
  chromium)  FLATPAK_ID="org.chromium.Chromium";                     TYPE="chromium" ;;
  edge)      FLATPAK_ID="com.microsoft.Edge";                        TYPE="chromium" ;;
  vivaldi)   FLATPAK_ID="com.vivaldi.Vivaldi";                       TYPE="chromium" ;;
  firefox)   FLATPAK_ID="org.mozilla.firefox";                       TYPE="firefox"  ;;
  librewolf) FLATPAK_ID="io.gitlab.librewolf-community";             TYPE="firefox"  ;;
  floorp)    FLATPAK_ID="one.ablaze.floorp";                         TYPE="firefox"  ;;
  zen)       FLATPAK_ID="app.zen_browser.zen";                       TYPE="firefox"  ;;
  *)         FLATPAK_ID="$BROWSER";                                  TYPE="" ;;
esac

# If a raw app id was passed, infer the engine from known browser lists.
if [ -z "$TYPE" ]; then
  case "$FLATPAK_ID" in
    com.google.Chrome|com.brave.Browser|com.vivaldi.Vivaldi|com.opera.Opera|com.microsoft.Edge|ru.yandex.Browser|org.chromium.Chromium|io.github.ungoogled_software.ungoogled_chromium)
      TYPE="chromium" ;;
    org.mozilla.firefox|one.ablaze.floorp|io.gitlab.librewolf-community|org.torproject.torbrowser-launcher|app.zen_browser.zen|org.garudalinux.firedragon|net.mullvad.MullvadBrowser|net.waterfox.waterfox)
      TYPE="firefox" ;;
    *)
      echo "ERROR: cannot tell whether '$FLATPAK_ID' is Chromium- or Firefox-based." >&2
      echo "       Pass a known name (brave|chrome|firefox) or extend this script." >&2
      exit 1 ;;
  esac
fi

# Sanity checks
if ! command -v flatpak >/dev/null 2>&1; then
  echo "ERROR: flatpak not found." >&2; exit 1
fi
if ! flatpak info "$FLATPAK_ID" >/dev/null 2>&1; then
  echo "ERROR: Flatpak '$FLATPAK_ID' is not installed for this user." >&2
  echo "       Install it first, e.g.: flatpak install flathub $FLATPAK_ID" >&2
  exit 1
fi
if [ ! -x /opt/1Password/1Password-BrowserSupport ]; then
  echo "WARN: /opt/1Password/1Password-BrowserSupport not found — is the native 1Password app installed?" >&2
fi

echo "Configuring 1Password integration for $FLATPAK_ID ($TYPE)..."

# 1. Let the sandboxed browser run host programs (so the wrapper can reach 1Password)
flatpak override --user --talk-name=org.freedesktop.Flatpak "$FLATPAK_ID"

# 2. Wrapper script inside the browser's per-app data dir
WRAPPER_DIR="$HOME/.var/app/$FLATPAK_ID/data/bin"
WRAPPER="$WRAPPER_DIR/1password-wrapper.sh"
mkdir -p "$WRAPPER_DIR"
cat > "$WRAPPER" <<'WRAP'
#!/bin/bash
if [ "${container-}" = flatpak ]; then
    flatpak-spawn --host /opt/1Password/1Password-BrowserSupport "$@"
else
    exec /opt/1Password/1Password-BrowserSupport "$@"
fi
WRAP
chmod +x "$WRAPPER"

# 3. Locate the browser's native-messaging-hosts dir (engine-specific)
if [ "$TYPE" = "chromium" ]; then
  ALLOWED="$CHROMIUM_ALLOWED"
  NMH_DIR="$(find "$HOME/.var/app/$FLATPAK_ID/config" -maxdepth 3 -type d -name NativeMessagingHosts 2>/dev/null | head -n1)"
  if [ -z "$NMH_DIR" ]; then
    # Profile not created yet — fall back to the browser's default config subdir
    case "$FLATPAK_ID" in
      com.brave.Browser)     SUB="BraveSoftware/Brave-Browser" ;;
      com.google.Chrome)     SUB="google-chrome" ;;
      org.chromium.Chromium) SUB="chromium" ;;
      com.microsoft.Edge)    SUB="microsoft-edge" ;;
      com.vivaldi.Vivaldi)   SUB="vivaldi" ;;
      *)                     SUB="" ;;
    esac
    if [ -z "$SUB" ]; then
      echo "ERROR: no NativeMessagingHosts dir yet and no default known for $FLATPAK_ID." >&2
      echo "       Launch the browser once, then re-run this." >&2
      exit 1
    fi
    NMH_DIR="$HOME/.var/app/$FLATPAK_ID/config/$SUB/NativeMessagingHosts"
  fi
else
  ALLOWED="$FIREFOX_ALLOWED"
  # Firefox keeps native-messaging-hosts next to the profile dir (the one with
  # profiles.ini), e.g. .mozilla/firefox/profiles.ini -> .mozilla/native-messaging-hosts
  NMH_DIR=""
  shopt -s nullglob dotglob
  for dir in "$HOME/.var/app/$FLATPAK_ID"/*; do
    [ -d "$dir" ] || continue
    if [ -f "$dir/profiles.ini" ]; then NMH_DIR="$dir/native-messaging-hosts"; break; fi
    for sub in "$dir"/*; do
      [ -d "$sub" ] || continue
      if [ -f "$sub/profiles.ini" ]; then NMH_DIR="$dir/native-messaging-hosts"; break 2; fi
    done
  done
  [ -z "$NMH_DIR" ] && NMH_DIR="$HOME/.var/app/$FLATPAK_ID/.mozilla/native-messaging-hosts"
fi

# 4. Write the native-messaging manifest pointing at the wrapper
mkdir -p "$NMH_DIR"
cat > "$NMH_DIR/com.1password.1password.json" <<EOF
{
    "name": "com.1password.1password",
    "description": "1Password BrowserSupport",
    "path": "$WRAPPER",
    "type": "stdio",
    $ALLOWED
}
EOF

# 5. The system allowlist is baked into the image; warn if it was stripped
if ! grep -qs 'flatpak-session-helper' /etc/1password/custom_allowed_browsers; then
  echo "WARN: /etc/1password/custom_allowed_browsers is missing 'flatpak-session-helper'." >&2
  echo "      Fix: echo flatpak-session-helper | sudo tee -a /etc/1password/custom_allowed_browsers" >&2
fi

echo "Done. Restart $FLATPAK_ID and the 1Password app, then turn on"
echo "'Integrate with 1Password in the browser' in the extension settings."
